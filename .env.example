# Zadarma CRM API Configuration
# Get these from your Zadarma account dashboard
ZADARMA_API_KEY=your_zadarma_api_key_here
ZADARMA_SECRET=your_zadarma_secret_here

# Next.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Directus CMS Configuration (if not already configured)
